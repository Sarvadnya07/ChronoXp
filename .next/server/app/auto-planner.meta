{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/auto-planner/layout,_N_T_/auto-planner/page,_N_T_/auto-planner"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/auto-planner/__PAGE__",
    "/auto-planner",
    "/_index",
    "/_head"
  ]
}